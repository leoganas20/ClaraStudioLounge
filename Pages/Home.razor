            <p style="color: var(--text-light); font-size: 0.95rem; line-height: 1.8;">A selection of moments stolen from time, preserved with the precision of a master artisan.</p>
        </div>
    </div>

    <div class="gallery">
        <div class="gallery-item wide animate-up">
            <img src="https://images.unsplash.com/photo-1511285560929-80b456fea0bc?auto=format&fit=crop&w=1600&q=80" alt="Wedding Vows">
            <div class="gallery-overlay">
                <p class="caps">Collection I</p>
                <h3>Timeless Vows</h3>
            </div>
        </div>
        <div class="gallery-item tall animate-up delay-1">
            <img src="https://images.unsplash.com/photo-1519225495045-3b363285e64d?auto=format&fit=crop&w=800&q=80" alt="Bridal Elegance">
            <div class="gallery-overlay">
                <p class="caps">Portraits</p>
                <h3>The Bride</h3>
            </div>
        </div>
        <div class="gallery-item animate-up delay-2">
            <img src="https://images.unsplash.com/photo-1519741497674-611481863552?auto=format&fit=crop&w=1000&q=80" alt="Reception Joy">
            <div class="gallery-overlay">
                <p class="caps">Atmosphere</p>
                <h3>Golden Hour</h3>
            </div>
        </div>
        <div class="gallery-item animate-up delay-3">
            <img src="https://images.unsplash.com/photo-1465495910483-0d67498c8f1e?auto=format&fit=crop&w=1000&q=80" alt="Couple Connection">
            <div class="gallery-overlay">
