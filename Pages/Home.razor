<style>
    .animate-up {
        opacity: 0;
        transform: translateY(40px);
        animation: fadeInUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    .delay-1 { animation-delay: 0.2s; }
    .delay-2 { animation-delay: 0.4s; }
    .delay-3 { animation-delay: 0.6s; }

    .portfolio-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 6rem;
    }

    .portfolio-intro {
        max-width: 350px;
        text-align: right;
    }

    .contact-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 6rem;
        align-items: start;
    }

    @@media (max-width: 992px) {
        .portfolio-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 2rem;
            margin-bottom: 4rem;
        }
        .portfolio-intro {
            max-width: 100%;
            text-align: left;
        }
        .contact-grid {
            grid-template-columns: 1fr;
            gap: 4rem;
        }
        .services-header {
            margin-bottom: 4rem !important;
        }
    }

    @@keyframes fadeInUp {
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@media (max-width: 768px) {
        h2 {
            font-size: 2.5rem !important;
        }
    }
</style>

@code {
    private double scrollOffset = 0;
    private ElementReference scrollerRef;

    [Inject] private IJSRuntime JSRuntime { get; set; } = default!;
    private System.Timers.Timer? _timer;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("setupScrollListener", DotNetObjectReference.Create(this));
            StartAutoScroll();
        }
    }

    private void StartAutoScroll()
    {
        _timer = new System.Timers.Timer(3000);
        _timer.Elapsed += async (sender, e) => {
            await InvokeAsync(async () => {
                await ScrollNext();
            });
        };
        _timer.AutoReset = true;
        _timer.Enabled = true;
    }

    [JSInvokable]
    public void OnScroll(double scrollY)
    {
        scrollOffset = scrollY;
        StateHasChanged();
    }

    private async Task ScrollNext()
    {
        await JSRuntime.InvokeVoidAsync("eval", @"
            const container = document.querySelector('.scroller-container');
            if (container) {
                if (container.scrollLeft + container.clientWidth >= container.scrollWidth - 50) {
                    container.scrollTo({ left: 0, behavior: 'smooth' });
                } else {
                    container.scrollBy({ left: 400, behavior: 'smooth' });
                }
            }
        ");
    }

    private async Task ScrollPrev()
    {
        await JSRuntime.InvokeVoidAsync("eval", "document.querySelector('.scroller-container')?.scrollBy({ left: -400, behavior: 'smooth' })");
        ResetTimer();
    }

    private void ResetTimer()
    {
        _timer?.Stop();
        _timer?.Start();
    }

    public void Dispose()
    {
        _timer?.Stop();
        _timer?.Dispose();
    }
}
