@page "/"

<section class="hero" style="background-image: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.3)), url('https://images.unsplash.com/photo-1544078751-58fee2d8a03b?auto=format&fit=crop&w=1920&q=80');">
    <div class="container hero-content">
        <h1 class="animate-up">Clara Studio Lounge</h1>
        <p class="animate-up delay-1">Elegance in Every Frame</p>
        <div class="animate-up delay-2" style="margin-top: 2rem;">
            <a href="#contact" class="btn btn-primary">Book an Experience</a>
            <a href="#portfolio" class="btn btn-outline" style="margin-left: 1rem;">View Collections</a>
        </div>
    </div>
</section>

<section id="portfolio" class="container">
    <div style="text-align: center; margin-bottom: 5rem;">
        <h2 style="font-size: 3.5rem; margin-bottom: 1.5rem;">The Collections</h2>
        <p style="color: var(--text-light); text-transform: uppercase; letter-spacing: 3px; font-size: 0.9rem;">Moments stolen from time, preserved forever</p>
    </div>

    <div class="gallery">
        <div class="gallery-item animate-up">
            <img src="https://images.unsplash.com/photo-1511285560929-80b456fea0bc?auto=format&fit=crop&w=800&q=80" alt="Wedding Vows">
            <div class="gallery-overlay">
                <h3>Timeless Vows</h3>
                <p>The beginning of forever</p>
            </div>
        </div>
        <div class="gallery-item animate-up delay-1">
            <img src="https://images.unsplash.com/photo-1519741497674-611481863552?auto=format&fit=crop&w=800&q=80" alt="Reception Joy">
            <div class="gallery-overlay">
                <h3>Elegant Soirées</h3>
                <p>Celebrating love in style</p>
            </div>
        </div>
        <div class="gallery-item animate-up delay-2">
            <img src="https://images.unsplash.com/photo-1519225495045-3b363285e64d?auto=format&fit=crop&w=800&q=80" alt="Bridal Elegance">
            <div class="gallery-overlay">
                <h3>Quiet Moments</h3>
                <p>The beauty in the details</p>
            </div>
        </div>
        <div class="gallery-item animate-up">
            <img src="https://images.unsplash.com/photo-1465495910483-0d67498c8f1e?auto=format&fit=crop&w=800&q=80" alt="Couple Connection">
            <div class="gallery-overlay">
                <h3>Intimate Bonds</h3>
                <p>Your story, told through our lens</p>
            </div>
        </div>
    </div>
</section>

<section id="services">
    <div class="container">
        <div style="text-align: center; margin-bottom: 5rem;">
            <h2 style="font-size: 3.5rem; margin-bottom: 1.5rem;">Our Services</h2>
            <p style="color: var(--text-light); text-transform: uppercase; letter-spacing: 3px; font-size: 0.9rem;">Excellence in every detail</p>
        </div>

        <div class="grid grid-3">
            <div class="card animate-up">
                <h3 style="margin-bottom: 1.5rem; color: var(--accent);">Cinematic Art</h3>
                <p style="color: var(--text-light); margin-bottom: 2rem;">Bespoke wedding photography that captures the raw emotion and sophisticated elegance of your special day.</p>
                <ul style="list-style: none; color: var(--text-light); font-size: 0.9rem;">
                    <li style="margin-bottom: 0.8rem; border-bottom: 1px solid #eee; padding-bottom: 0.5rem;">Full Day Premiere Coverage</li>
                    <li style="margin-bottom: 0.8rem; border-bottom: 1px solid #eee; padding-bottom: 0.5rem;">Artisan Post-Production</li>
                    <li style="margin-bottom: 0.8rem;">Private Digital Archive</li>
                </ul>
            </div>
            <div class="card animate-up delay-1">
                <h3 style="margin-bottom: 1.5rem; color: var(--accent);">Coordination</h3>
                <p style="color: var(--text-light); margin-bottom: 2rem;">Seamless event planning and meticulous coordination, allowing you to immerse yourself fully in the celebration.</p>
                <ul style="list-style: none; color: var(--text-light); font-size: 0.9rem;">
                    <li style="margin-bottom: 0.8rem; border-bottom: 1px solid #eee; padding-bottom: 0.5rem;">Bespoke Timeline Design</li>
                    <li style="margin-bottom: 0.8rem; border-bottom: 1px solid #eee; padding-bottom: 0.5rem;">Curation of Elite Vendors</li>
                    <li style="margin-bottom: 0.8rem;">On-site Executive Management</li>
                </ul>
            </div>
            <div class="card animate-up delay-2">
                <h3 style="margin-bottom: 1.5rem; color: var(--accent);">The Collection</h3>
                <p style="color: var(--text-light); margin-bottom: 2rem;">Our flagship experience, where flawless coordination meets evocative imagery for the ultimate luxury wedding.</p>
                <ul style="list-style: none; color: var(--text-light); font-size: 0.9rem;">
                    <li style="margin-bottom: 0.8rem; border-bottom: 1px solid #eee; padding-bottom: 0.5rem;">Full-Service Wedding Planning</li>
                    <li style="margin-bottom: 0.8rem; border-bottom: 1px solid #eee; padding-bottom: 0.5rem;">Signature Engagement Session</li>
                    <li style="margin-bottom: 0.8rem;">Heirloom Leather-bound Album</li>
                </ul>
            </div>
        </div>
    </div>
</section>

<section id="contact" class="container" style="text-align: center; padding-bottom: 150px;">
    <div style="max-width: 650px; margin: 0 auto;">
        <h2 style="font-size: 3.5rem; margin-bottom: 1.5rem;">Inquire</h2>
        <p style="color: var(--text-light); margin-bottom: 4rem; line-height: 1.8;">If you resonate with our aesthetic and value the preservation of your most cherished memories, we invite you to reach out.</p>
        
        <form @onsubmit:preventDefault style="display: flex; flex-direction: column; gap: 1.5rem; text-align: left;">
            <input type="text" placeholder="Full Name" style="padding: 1.2rem; border: none; background: #fff; font-family: inherit; font-size: 0.9rem;">
            <input type="email" placeholder="Email Address" style="padding: 1.2rem; border: none; background: #fff; font-family: inherit; font-size: 0.9rem;">
            <textarea placeholder="Tell us about your celebration..." rows="6" style="padding: 1.2rem; border: none; background: #fff; font-family: inherit; font-size: 0.9rem; resize: vertical;"></textarea>
            <button type="submit" class="btn btn-primary" style="margin-top: 1.5rem; width: 100%;">Connect with us</button>
        </form>
    </div>
</section>

<style>
    .animate-up {
        opacity: 0;
        transform: translateY(30px);
        animation: fadeInUp 0.8s forwards;
    }

    .delay-1 { animation-delay: 0.2s; }
    .delay-2 { animation-delay: 0.4s; }

    @@keyframes fadeInUp {
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>
