@page "/"
@implements IDisposable

<section class="hero">
    <div class="hero-image-bg parallax-bg" style="--scroll-offset: @(scrollOffset * 0.4)px">
        <img src="https://images.unsplash.com/photo-1492691527719-9d1e07e534b4?auto=format&fit=crop&w=1920&q=80" alt="Studio Background">
    </div>
    <div class="container hero-content">
        <p class="caps animate-up" style="color: var(--accent); margin-bottom: 2rem;">A Fine Art Creative Studio</p>
        <div class="hero-logo-wrapper animate-up delay-1">
            <img src="images/logo.png" alt="Clara Studio Lounge" class="hero-logo" />
        </div>
        <p class="animate-up delay-2">Capturing the poetry of your most significant moments with a modern, editorial aesthetic.</p>
        <div class="animate-up delay-3 btn-group">
            <a href="#contact" class="btn btn-primary caps">Inquire Now</a>
            <a href="#portfolio" class="btn btn-outline caps">View Anthology</a>
        </div>
    </div>
</section>

<section id="portfolio" class="container">
